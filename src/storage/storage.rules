
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Permite que qualquer pessoa com a URL de download (que inclui um token de acesso)
    // possa ler o arquivo. Isso é necessário para que os players de vídeo/áudio
    // nos navegadores possam exibir o conteúdo. A escrita continua protegida.
    match /users/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
