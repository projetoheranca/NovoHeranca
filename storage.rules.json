
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Permite que qualquer usuário autenticado leia e escreva em sua própria pasta
    match /users/{userId}/{allPaths=**} {
      allow read;
      
      // Permite escrita sem limitação de tamanho no lado do cliente.
      // O plano Blaze gerenciará os limites e o faturamento.
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Regra de fallback: nega acesso a todos os outros caminhos
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
